# 1. Descargar la base de datos directamente desde el repositorio de la UCI
url <- "https://archive.ics.uci.edu/ml/machine-learning-databases/car/car.data"
datos_coches <- read.csv(url, header = FALSE, stringsAsFactors = TRUE)
# 2. Asignar los nombres correctos a las columnas según la documentación oficial
colnames(datos_coches) <- c("buying", "maint", "doors", "persons", "lug_boot", "safety", "class")
# 3. Exportar la base de datos completa a un archivo CSV en tu computadora
write.csv(datos_coches, "base_datos_car_evaluation.csv", row.names = FALSE)
# Mensaje de confirmación
print("¡El archivo 'base_datos_car_evaluation.csv' con los 1,728 datos reales se ha guardado con éxito!")
